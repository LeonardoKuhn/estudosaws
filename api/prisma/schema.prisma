// Minimal Prisma schema for the deploy study.
// A single model: each processed click becomes a row in "Click".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Click {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}
