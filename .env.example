# ===========================================================================
# Environment variables for the study. Copy to `.env` (NEVER commit the real .env):
#   cp .env.example .env
#
# docker-compose automatically reads the `.env` file in the project root.
# ===========================================================================

# --- Postgres (used by the postgres service and to build the DATABASE_URL) ---
POSTGRES_USER=estudo
POSTGRES_PASSWORD=estudo
POSTGRES_DB=estudo

# --- API / worker (inside the compose, hostnames are the service names) ---
# To run the API outside the compose, replace `postgres`/`redis` with `localhost`.
DATABASE_URL=postgresql://estudo:estudo@postgres:5432/estudo?schema=public
REDIS_URL=redis://redis:6379
PORT=3000

# --- Frontend (web/), runs outside the compose with `npm run dev` ---
# Base URL of the API that the browser will call.
# The API is published on the host at port 3010 (3000 is often already in use).
NEXT_PUBLIC_API_URL=http://localhost:3010
