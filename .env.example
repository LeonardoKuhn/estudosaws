# ===========================================================================
# Variáveis de ambiente do estudo. Copie para `.env` (NUNCA commite o .env real):
#   cp .env.example .env
#
# O docker-compose lê automaticamente o arquivo `.env` na raiz.
# ===========================================================================

# --- Postgres (usado pelo serviço postgres e para montar a DATABASE_URL) ---
POSTGRES_USER=estudo
POSTGRES_PASSWORD=estudo
POSTGRES_DB=estudo

# --- API / worker (dentro do compose os hostnames são os nomes dos serviços) ---
# Para rodar a API fora do compose, troque `postgres`/`redis` por `localhost`.
DATABASE_URL=postgresql://estudo:estudo@postgres:5432/estudo?schema=public
REDIS_URL=redis://redis:6379
PORT=3000

# --- Frontend (web/), roda fora do compose com `npm run dev` ---
# URL base da API que o browser vai chamar.
# A API é publicada no host na porta 3010 (3000 costuma estar ocupada).
NEXT_PUBLIC_API_URL=http://localhost:3010
